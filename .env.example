# Go With Sally Mobile App Configuration
# Copy this file to .env and set your values

# API Configuration - Change to your server IP/URL
API_URL=http://YOUR_SERVER_IP:5000
SOCKET_URL=http://YOUR_SERVER_IP:5000

# For production:
# API_URL=https://api.gowithsally.com
# SOCKET_URL=https://api.gowithsally.com

# Google Maps API Key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Environment
NODE_ENV=development


